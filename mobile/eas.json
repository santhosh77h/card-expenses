{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "autoIncrement": true,
        "image": "latest",
        "buildConfiguration": "Release"
      }
    },
    "production-apk": {
      "distribution": "internal",
      "developmentClient": false,
      "android": {
        "buildType": "apk"
      }
    }
  }
}
