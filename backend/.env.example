# --- Application ---
ENVIRONMENT=development          # development | staging | production
CORS_ORIGINS=["*"]               # JSON list of allowed origins
MAX_FILE_SIZE_MB=10
LOG_LEVEL=INFO
LOG_JSON=false                   # true for structured JSON logs (production)

# --- OpenAI (required for LLM parsing) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=45.0

# --- OpenRouter (multi-LLM consensus) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT=45.0

# --- Consensus ---
CONSENSUS_ENABLED=true
LLM2_MODEL=anthropic/claude-3.5-haiku
LLM3_MODEL=google/gemini-2.0-flash-001

# --- Stage 1: Document Intelligence ---
PROBE_MODEL=gpt-4o-mini
PROBE_TIMEOUT=15.0

# --- Dashboard (observability web UI) ---
DASHBOARD_ENABLED=true
DASHBOARD_DB_PATH=data/dashboard.db

# --- LangSmith (observability) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=vector-statement-parser
